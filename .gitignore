# macOS
.DS_Store

# Dependencies
node_modules/

# Build outputs (regenerated by `npm run build`; not committed). The esbuild
# bundle lands in public/dist/ and tsc's outDir is the root dist/. A no-leading-
# slash `dist/` already matches both, but public/dist/ is listed for clarity.
dist/
public/dist/

# Staged Doom source for the patch-based engine build
.build/

# Local base IWADs. Doom Perf map PWADs under public/maps/ are authored here.
public/wads/*.wad
public/wads/*.WAD
!public/wads/freedoom1.wad

# IDE
.idea/
*.swp
*.swo

# Playwright screencaps
playwright-*

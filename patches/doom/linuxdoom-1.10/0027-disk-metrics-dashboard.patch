+// Doom Perf: the media-pit METRICS DASHBOARD (storage wing). A wall panel of
+// three scrolling graphs -- LATENCY (disk await), IOPS (queue depth), READ/S
+// (utilization) -- repainted by R_DoomPerfDiskDashboardPixel from this sample
+// ring. We advance the ring a few tics apart so the scroll reads at a calm pace,
+// and decay the easter-egg IOPS spike every tic. Samples are permille (0..1000).
+#define DOOMPERF_DASH_SECTIONS		3
+#define DOOMPERF_DASH_ADVANCE_TICS	24	// ~0.69s/sample: a slow, calm drift left
+// DOOMPERF_DASH_SPIKE_TICS lives in doom_emscripten_compat.h (shared with the
+// browser's DoomPerf_TriggerStorageIopsSpike setter).
+
+int	doomperf_disk_dashboard[DOOMPERF_DASH_SECTIONS][DOOMPERF_DASH_SAMPLES];
+
+static int DoomPerf_DashClamp (int v)
+{
+    if (v < 0)
+	return 0;
+    if (v > 1000)
+	return 1000;
+    return v;
+}
+
+void DoomPerf_UpdateDiskDashboard (void)
+{
+    static int	seeded = 0;
+    int		await;
+    int		queue;
+    int		util;
+    int		wob;
+    int		latency;
+    int		iops;
+    int		read;
+    int		s;
+    int		i;
+
+    // Seed with a gentle baseline so the panel reads as a live dashboard from the
+    // first frame rather than an empty plot that fills in over the first seconds.
+    if (!seeded)
+    {
+	for (s = 0; s < DOOMPERF_DASH_SECTIONS; s++)
+	    for (i = 0; i < DOOMPERF_DASH_SAMPLES; i++)
+		doomperf_disk_dashboard[s][i] = 170 + ((i * 7 + s * 23) % 60);
+	seeded = 1;
+    }
+
+    if (doomperf_storage_iops_spike > 0)
+	doomperf_storage_iops_spike--;
+
+    if (leveltime % DOOMPERF_DASH_ADVANCE_TICS != 0)
+	return;
+
+    // Sim-aware effective signals, mirroring the platter/gauge/queue helpers: the
+    // disk sims synthesize their own values; live and the CPU/memory sims use the
+    // browser-pushed telemetry.
+    if (doomperf_sim_mode == 3)
+    {
+	await = 60;
+	queue = 80;
+	util = 910;
+    }
+    else if (doomperf_sim_mode == 4)
+    {
+	await = 720;
+	queue = 640;
+	util = 975;
+    }
+    else
+    {
+	await = doomperf_storage_await;
+	queue = doomperf_storage_queue;
+	util = doomperf_storage_util;
+    }
+
+    // A small wobble keeps an idle signal breathing instead of flatlining.
+    wob = (leveltime / DOOMPERF_DASH_ADVANCE_TICS) & 3;
+
+    latency = 150 + (await * 3) / 4 + wob * 12;
+    iops    = 150 + (queue * 3) / 5 + util / 8 + wob * 14;
+    read    = 140 + (util * 3) / 5 + wob * 12;
+
+    // Easter egg: while a spike is live, slam the freshest IOPS samples to the
+    // top of the chart (a tall, near-flat cap that only eases off as the spike
+    // ends), so each yell paints one unmistakable spike that then drifts left.
+    if (doomperf_storage_iops_spike > 0)
+	iops += 500 + (450 * doomperf_storage_iops_spike) / DOOMPERF_DASH_SPIKE_TICS;
+
+    latency = DoomPerf_DashClamp(latency);
+    iops = DoomPerf_DashClamp(iops);
+    read = DoomPerf_DashClamp(read);
+
+    // Scroll left; append the newest sample at the right edge.
+    for (s = 0; s < DOOMPERF_DASH_SECTIONS; s++)
+	for (i = 0; i < DOOMPERF_DASH_SAMPLES - 1; i++)
+	    doomperf_disk_dashboard[s][i] = doomperf_disk_dashboard[s][i + 1];
+    doomperf_disk_dashboard[0][DOOMPERF_DASH_SAMPLES - 1] = latency;
+    doomperf_disk_dashboard[1][DOOMPERF_DASH_SAMPLES - 1] = iops;
+    doomperf_disk_dashboard[2][DOOMPERF_DASH_SAMPLES - 1] = read;
+}
+
 // Doom Perf: MEMORY page-bank instruments. Tags 500..544 are the 9x5 page
 // cells, 546/547 are swap-in/out channels, 548 is the OOM bay, and 549/550 are
 // PSI some/full pads. Utilization raises and brightens page cells. Saturation
@@ -763,6 +861,7 @@ void P_Ticker (void)
 
     DoomPerf_UpdatePillars ();
     DoomPerf_UpdatePlatter ();
+    DoomPerf_UpdateDiskDashboard ();
     DoomPerf_UpdateMemoryWing ();
     DoomPerf_UpdateRunQueueParticles ();
 

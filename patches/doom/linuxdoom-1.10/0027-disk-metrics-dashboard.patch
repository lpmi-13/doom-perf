+// Storage media-pit metrics dashboard (storage wing). The panel's room-facing
+// lower texture is the static DPDDASH art (titles, section frames, grid, axes,
+// baseline bars); this hook repaints only the three plot rectangles with the
+// live scrolling sample ring that p_tick.c advances, and returns the source
+// texel (background) everywhere else so the static art shows through unchanged.
+// tx/ty index the 128x128 texture; the chart geometry mirrors
+// buildStorageDisplayPatch() in scripts/lib/textures.mjs -- keep them in step.
+#define DOOMPERF_DASH_CHART_X	50
+#define DOOMPERF_DASH_CHART_W	72
+#define DOOMPERF_DASH_CHART_H	22
+#define DOOMPERF_DASH_PITCH	4
+#define DOOMPERF_DASH_BAR_W	3
+// Palette indices shared with the static art.
+#define DOOMPERF_DASH_WHITE	4
+#define DOOMPERF_DASH_GRID	96
+#define DOOMPERF_DASH_AXIS	0
+#define DOOMPERF_DASH_BAR_A	200
+#define DOOMPERF_DASH_BAR_B	204
+#define DOOMPERF_DASH_BAR_CAP	206
+
+extern int doomperf_disk_dashboard[3][DOOMPERF_DASH_SAMPLES];
+
+static byte R_DoomPerfDiskDashboardPixel (int tx, int ty, byte background)
+{
+    int		section;
+    int		cx;
+    int		cy;
+    int		index;
+    int		x0;
+    int		value;
+    int		fill;
+    int		bartop;
+
+    tx &= 127;
+
+    // Each plot rectangle is chartY..chartY+22 tall; the three sections sit 40
+    // texels apart (chartY 17 / 57 / 97). Rows outside them are static art.
+    if (ty >= 17 && ty < 39)		section = 0;	// LATENCY
+    else if (ty >= 57 && ty < 79)	section = 1;	// IOPS
+    else if (ty >= 97 && ty < 119)	section = 2;	// READ/S
+    else
+	return background;
+
+    if (tx < DOOMPERF_DASH_CHART_X
+	|| tx >= DOOMPERF_DASH_CHART_X + DOOMPERF_DASH_CHART_W)
+	return background;				// title gutter / right margin
+
+    cx = tx - DOOMPERF_DASH_CHART_X;			// 0 .. 71
+    cy = ty - (17 + section * 40);			// 0 .. 21 within the plot
+
+    // Bars (topmost): 15 samples filled from the baseline up by value.
+    if (cx >= 4)
+    {
+	index = (cx - 4) / DOOMPERF_DASH_PITCH;
+	x0 = 4 + index * DOOMPERF_DASH_PITCH;
+	if (index < DOOMPERF_DASH_SAMPLES && cx < x0 + DOOMPERF_DASH_BAR_W)
+	{
+	    value = doomperf_disk_dashboard[section][index];
+	    if (value < 0)
+		value = 0;
+	    if (value > 1000)
+		value = 1000;
+	    fill = (value * (DOOMPERF_DASH_CHART_H - 5)) / 1000;
+	    if (fill < 2)
+		fill = 2;
+	    bartop = (DOOMPERF_DASH_CHART_H - 2) - fill;
+	    if (cy >= bartop && cy < DOOMPERF_DASH_CHART_H - 2)
+		return (cy == bartop)
+		    ? DOOMPERF_DASH_BAR_CAP
+		    : ((index & 1) ? DOOMPERF_DASH_BAR_B : DOOMPERF_DASH_BAR_A);
+	}
+    }
+
+    // Axes: left edge column and the baseline row.
+    if (cx == 0 || cy == DOOMPERF_DASH_CHART_H - 1)
+	return DOOMPERF_DASH_AXIS;
+
+    // Grid: horizontal every 6 rows, vertical every 12 columns.
+    if (cy > 0 && (cy % 6) == 0)
+	return DOOMPERF_DASH_GRID;
+    if (cx >= 12 && (cx % 12) == 0)
+	return DOOMPERF_DASH_GRID;
+
+    return DOOMPERF_DASH_WHITE;
+}

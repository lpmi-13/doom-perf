diff --git a/r_draw.c b/r_draw.c
--- a/r_draw.c
+++ b/r_draw.c
@@ -514,6 +514,173 @@
 // just for profiling
 int			dscount;
 
+// Doom Perf: CPU room instrument floors. The core chamber shows one geometric
+// cell per logical CPU while two physically separate saturation chambers map
+// instantaneous runnable queue and sustained load overcommit. build-doomperf-map.mjs aligns the display
+// sectors to these grids; r_plane.c selects one special span path at a time.
+#define DOOMPERF_CPU_GRID_X0		-128
+#define DOOMPERF_CPU_GRID_Y0		992
+#define DOOMPERF_CPU_GRID_COLUMNS	8
+#define DOOMPERF_CPU_GRID_CELL_SIZE	32
+
+#define DOOMPERF_CPU_RUN_QUEUE_X0	-672
+#define DOOMPERF_CPU_RUN_QUEUE_Y0	1000
+#define DOOMPERF_CPU_RUN_QUEUE_WIDTH	224
+#define DOOMPERF_CPU_RUN_QUEUE_HEIGHT	240
+
+#define DOOMPERF_CPU_CORE_DARK		5
+#define DOOMPERF_CPU_CORE_FRAME		96
+#define DOOMPERF_CPU_CORE_BLUE		200
+#define DOOMPERF_CPU_CORE_GREEN		112
+#define DOOMPERF_CPU_CORE_YELLOW	231
+#define DOOMPERF_CPU_CORE_RED		176
+
+int			doomperf_cpu_floor_display;
+
+static int R_DoomPerfAbs (int value)
+{
+    return value < 0 ? -value : value;
+}
+
+static byte R_DoomPerfCpuColor (int permille)
+{
+    if (permille < 350)
+	return DOOMPERF_CPU_CORE_BLUE;
+    if (permille < 700)
+	return DOOMPERF_CPU_CORE_GREEN;
+    if (permille < 900)
+	return DOOMPERF_CPU_CORE_YELLOW;
+    return DOOMPERF_CPU_CORE_RED;
+}
+
+static byte R_DoomPerfCpuPressureColor (int permille)
+{
+    if (permille < 250)
+	return DOOMPERF_CPU_CORE_BLUE;
+    if (permille < 550)
+	return DOOMPERF_CPU_CORE_GREEN;
+    if (permille < 800)
+	return DOOMPERF_CPU_CORE_YELLOW;
+    return DOOMPERF_CPU_CORE_RED;
+}
+
+static int R_DoomPerfCpuWorldX (fixed_t xfrac)
+{
+    return xfrac >> FRACBITS;
+}
+
+static int R_DoomPerfCpuWorldY (fixed_t yfrac)
+{
+    return -(yfrac >> FRACBITS);
+}
+
+static byte
+R_DoomPerfCpuCorePixel
+( fixed_t		xfrac,
+  fixed_t		yfrac,
+  byte			background )
+{
+    int			worldx;
+    int			worldy;
+    int			gridx;
+    int			gridy;
+    int			cellx;
+    int			celly;
+    int			core;
+    int			localx;
+    int			localy;
+    int			diamond;
+
+    worldx = R_DoomPerfCpuWorldX(xfrac);
+    worldy = R_DoomPerfCpuWorldY(yfrac);
+    gridx = worldx - DOOMPERF_CPU_GRID_X0;
+    gridy = worldy - DOOMPERF_CPU_GRID_Y0;
+    if (gridx < 0 || gridy < 0
+	|| gridx >= DOOMPERF_CPU_GRID_COLUMNS * DOOMPERF_CPU_GRID_CELL_SIZE
+	|| gridy >= DOOMPERF_CPU_GRID_COLUMNS * DOOMPERF_CPU_GRID_CELL_SIZE)
+	return background;
+
+    cellx = gridx / DOOMPERF_CPU_GRID_CELL_SIZE;
+    celly = gridy / DOOMPERF_CPU_GRID_CELL_SIZE;
+    core = celly * DOOMPERF_CPU_GRID_COLUMNS + cellx;
+    localx = gridx & (DOOMPERF_CPU_GRID_CELL_SIZE - 1);
+    localy = gridy & (DOOMPERF_CPU_GRID_CELL_SIZE - 1);
+
+    if (core >= doomperf_cpu_core_count)
+	return background;
+
+    // The active core is a bright diamond with a hard metal outline. Colour
+    // moves from cool blue through yellow to red as utilization rises.
+    diamond = R_DoomPerfAbs(localx - 15) + R_DoomPerfAbs(localy - 15);
+    if (diamond <= 10)
+	return R_DoomPerfCpuColor(doomperf_cpu_cores[core]);
+    if (diamond <= 13)
+	return DOOMPERF_CPU_CORE_FRAME;
+    if (diamond <= 15)
+	return DOOMPERF_CPU_CORE_DARK;
+    return background;
+}
+
+static byte
+R_DoomPerfCpuRunQueuePixel
+( fixed_t		xfrac,
+  fixed_t		yfrac,
+  byte			background )
+{
+    int			localx;
+    int			localy;
+    int			lane;
+    int			lane_x;
+    int			thread;
+    int			pulse;
+    int			active_width;
+
+    localx = R_DoomPerfCpuWorldX(xfrac) - DOOMPERF_CPU_RUN_QUEUE_X0;
+    localy = R_DoomPerfCpuWorldY(yfrac) - DOOMPERF_CPU_RUN_QUEUE_Y0;
+    if (localx < 0 || localy < 0
+	|| localx >= DOOMPERF_CPU_RUN_QUEUE_WIDTH
+	|| localy >= DOOMPERF_CPU_RUN_QUEUE_HEIGHT)
+	return background;
+
+    if (localx < 7 || localy < 7
+	|| localx >= DOOMPERF_CPU_RUN_QUEUE_WIDTH - 7
+	|| localy >= DOOMPERF_CPU_RUN_QUEUE_HEIGHT - 7)
+	return DOOMPERF_CPU_CORE_FRAME;
+
+    // Runnable tasks queue into eight machine-like lanes. More pressure
+    // thickens the bright packet in each lane, leaving dark grooves between.
+    lane = (localx - 8) / 26;
+    lane_x = (localx - 8) % 26;
+    if (lane < 0 || lane >= 8)
+	return background;
+    if (lane_x < 3 || lane_x > 20)
+	return DOOMPERF_CPU_CORE_DARK;
+
+    active_width = doomperf_cpu_run_queue_pressure ? 2 + doomperf_cpu_run_queue_pressure / 85 : 0;
+    thread = R_DoomPerfAbs(lane_x - 11);
+    pulse = (localy - leveltime * (1 + doomperf_cpu_run_queue_pressure / 250) + lane * 17) & 31;
+    if (thread <= active_width && pulse < 18)
+	return R_DoomPerfCpuPressureColor(doomperf_cpu_run_queue_pressure);
+    if ((localy & 31) < 3 && thread < 8)
+	return DOOMPERF_CPU_CORE_FRAME;
+    if (thread < 9)
+	return DOOMPERF_CPU_CORE_DARK;
+    return background;
+}
+
+static byte
+R_DoomPerfCpuFloorPixel
+( fixed_t		xfrac,
+  fixed_t		yfrac,
+  byte			background )
+{
+    if (doomperf_cpu_floor_display == 1)
+	return R_DoomPerfCpuCorePixel(xfrac, yfrac, background);
+    if (doomperf_cpu_floor_display == 2)
+	return R_DoomPerfCpuRunQueuePixel(xfrac, yfrac, background);
+    return background;
+}
+
 
 //
 // Draws the actual span.
@@ -553,7 +720,11 @@
 
 	// Lookup pixel from flat texture tile,
 	//  re-index using light/colormap.
-	*dest++ = ds_colormap[ds_source[spot]];
+	if (doomperf_cpu_floor_display)
+	    *dest++ = ds_colormap[R_DoomPerfCpuFloorPixel
+				  (xfrac, yfrac, ds_source[spot])];
+	else
+	    *dest++ = ds_colormap[ds_source[spot]];
 
 	// Next step in u,v.
 	xfrac += ds_xstep; 
@@ -676,8 +847,18 @@
 	spot = ((yfrac>>(16-6))&(63*64)) + ((xfrac>>16)&63);
 	// Lowres/blocky mode does it twice,
 	//  while scale is adjusted appropriately.
-	*dest++ = ds_colormap[ds_source[spot]]; 
-	*dest++ = ds_colormap[ds_source[spot]];
+	if (doomperf_cpu_floor_display)
+	{
+	    byte cpu_pixel = R_DoomPerfCpuFloorPixel
+		(xfrac, yfrac, ds_source[spot]);
+	    *dest++ = ds_colormap[cpu_pixel];
+	    *dest++ = ds_colormap[cpu_pixel];
+	}
+	else
+	{
+	    *dest++ = ds_colormap[ds_source[spot]]; 
+	    *dest++ = ds_colormap[ds_source[spot]];
+	}
 	
 	xfrac += ds_xstep; 
 	yfrac += ds_ystep; 

@@ -101,7 +101,31 @@
 //
 // R_InstallSpriteLump
 // Local function for R_InitSprites.
 //
+static void R_DoomPerfInitPatchedSpriteLump (int lump)
+{
+    int		index;
+    patch_t	*patch;
+
+    if (lump >= firstspritelump && lump <= lastspritelump)
+	return;
+
+    index = lump - firstspritelump;
+    if (index < 0 || index >= numspritelumps)
+	I_Error ("R_DoomPerfInitPatchedSpriteLump: "
+		 "sprite lump %i is outside metadata range", lump);
+
+    patch = W_CacheLumpNum (lump, PU_CACHE);
+    spritewidth[index] = SHORT(patch->width)<<FRACBITS;
+    spriteoffset[index] = SHORT(patch->leftoffset)<<FRACBITS;
+    spritetopoffset[index] = SHORT(patch->topoffset)<<FRACBITS;
+}
+

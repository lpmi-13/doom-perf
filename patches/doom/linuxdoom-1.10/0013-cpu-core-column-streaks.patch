+
+// Rising-streak procedural pixel for the eight CPU core pillars. Each pillar
+// is driven by per-core utilization (in permille). The texture column index
+// is supplied by r_segs.c so streaks stay locked to the wall surface.
+static byte R_DoomPerfCpuStreakPixel (int ty)
+{
+    int			core_id;
+    int			util;
+    int			tx;
+    int			seed;
+    int			density;
+    int			speed;
+    int			trail_len;
+    int			head_y;
+    int			offset;
+
+    core_id = doomperf_cpu_column_display - 1;
+    if (core_id < 0 || core_id >= 16)
+	return DOOMPERF_CPU_CORE_DARK;
+    util = (core_id < doomperf_cpu_core_count)
+	? doomperf_cpu_cores[core_id]
+	: 0;
+
+    // Density and streak parameters scale with utilization so a busy core
+    // packs more rising particles travelling faster with longer trails.
+    tx = doomperf_cpu_column_texture_x & 63;
+    seed = tx * 31 + core_id * 13 + (tx >> 2) * 7;
+    density = 5 + util / 50;
+    if (((seed * 17) & 31) >= density)
+	return DOOMPERF_CPU_CORE_DARK;
+
+    // Head descends from ty=127 toward ty=0 over time so streaks rise.
+    // Trail extends behind the head (toward higher ty).
+    speed = 1 + util / 200;
+    trail_len = 24 + util / 12;
+    head_y = (127 - ((leveltime * speed + seed * 11) & 127)) & 127;
+    offset = (ty - head_y + 128) & 127;
+    if (offset < 2)
+	return DOOMPERF_CPU_CORE_FRAME;
+    if (offset < trail_len)
+	return R_DoomPerfCpuColor(util);
+    return DOOMPERF_CPU_CORE_DARK;
+}

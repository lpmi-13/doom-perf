+// Doom Perf: CPU core pillars carry linedef tags 101..108. Before each
+// colfunc() call we inspect curline->linedef->tag and set the column
+// display globals consumed by R_DrawColumn.
+extern int doomperf_cpu_column_display;
+extern int doomperf_cpu_column_texture_x;
+
+static void R_DoomPerfBeginColumn (int texturecolumn)
+{
+    int		tag;
+
+    tag = curline->linedef->tag;
+    if (tag >= 101 && tag <= 116)
+	doomperf_cpu_column_display = tag - 100;
+    else
+	doomperf_cpu_column_display = 0;
+    doomperf_cpu_column_texture_x = texturecolumn;
+}

+// Storage (disk) wing: service-latency gauges. Palette aliases reuse the shared
+// instrument indices -- gold is the DISK label's hue (231), red the danger hue.
+#define DOOMPERF_DISK_EMPTY	DOOMPERF_CPU_CORE_DARK	/* 5  */
+#define DOOMPERF_DISK_FRAME	DOOMPERF_CPU_CORE_FRAME	/* 96 */
+#define DOOMPERF_DISK_GOLD	DOOMPERF_CPU_CORE_YELLOW	/* 231 */
+#define DOOMPERF_DISK_RED	DOOMPERF_CPU_CORE_RED	/* 176 */
+
+// Effective disk service time (iostat await) in permille of a 250ms full scale.
+// In live mode it is the value pushed from the browser (doomperf_storage_await);
+// the disk sims synthesize it so the gauges react without a real workload. Mode 3
+// (high utilization) stays low -- a busy disk that keeps up has little latency --
+// while mode 4 (saturation) blows the queue out and spikes await into the red.
+// The CPU sims (1/2) leave it on the live value, since disk isn't their subject.
+static int R_DoomPerfDiskAwaitPermille (void)
+{
+    switch (doomperf_sim_mode)
+    {
+      case 3:
+	return 26 + (leveltime % 16);
+      case 4:
+	return 660 + ((leveltime * 3) % 220);
+      default:
+	return doomperf_storage_await;
+    }
+}
+
+// A bank of three vertical await gauges in the media pit (gauge 0/1/2), with a
+// small per-column phase ripple so they shimmer like a live meter. Each 128-tall
+// niche wall fills from the bottom (ty 127) by await/service time; filled pixels
+// are gold up to the warning line (70% of the 250ms scale, ~175ms) and red above
+// it, so a healthy-busy disk shows a short gold bar and a saturated one spikes red.
+static byte R_DoomPerfDiskGaugePixel (int gauge, int ty)
+{
+    int		await;
+    int		fill_ty;
+    int		warn_ty;
+    int		tx;
+
+    if (gauge < 0 || gauge > 2)
+	return DOOMPERF_DISK_EMPTY;
+
+    tx = doomperf_cpu_column_texture_x & 127;
+    if (tx < 3 || tx > 124)
+	return DOOMPERF_DISK_FRAME;
+
+    await = R_DoomPerfDiskAwaitPermille() + (((leveltime >> 1) + gauge * 13) % 24) - 12;
+    if (await < 0)
+	await = 0;
+    if (await > 1000)
+	await = 1000;
+
+    fill_ty = 127 - (await * 127) / 1000;
+    warn_ty = 127 - (700 * 127) / 1000;
+
+    if (ty == warn_ty)
+	return DOOMPERF_DISK_FRAME;
+    if (ty < fill_ty)
+	return DOOMPERF_DISK_EMPTY;
+    if (ty < warn_ty)
+	return DOOMPERF_DISK_RED;
+    return DOOMPERF_DISK_GOLD;
+}
+
 static int R_DoomPerfCpuWorldX (fixed_t xfrac)
 {
     return xfrac >> FRACBITS;

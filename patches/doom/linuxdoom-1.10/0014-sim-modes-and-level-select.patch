+// Doom Perf: effective CPU telemetry. doomperf_sim_mode (set by the level-
+// select menu) overrides the live browser telemetry with canned scenarios so
+// the CPU room can be demonstrated without a real workload:
+//   0 = live (browser telemetry)
+//   1 = simulated high utilization (cores pinned near 100%)
+//   2 = simulated high saturation (busy cores + an overloaded run queue)
+static int R_DoomPerfCoreCount (void)
+{
+    if (doomperf_sim_mode != 0)
+	return DOOMPERF_CPU_GRID_COLUMNS;
+    return doomperf_cpu_core_count;
+}
+
+static int R_DoomPerfCorePermille (int core)
+{
+    switch (doomperf_sim_mode)
+    {
+      case 1:
+	return 880 + ((leveltime * 2 + core * 97) % 120);
+      case 2:
+	return 700 + ((leveltime + core * 53) % 200);
+      default:
+	return (core >= 0 && core < doomperf_cpu_core_count)
+	    ? doomperf_cpu_cores[core] : 0;
+    }
+}
+
+static int R_DoomPerfRunQueuePermille (void)
+{
+    switch (doomperf_sim_mode)
+    {
+      case 1:
+	return 150;
+      case 2:
+	return 840 + ((leveltime * 3) % 160);
+      default:
+	return doomperf_cpu_run_queue_pressure;
+    }
+}
+
+
